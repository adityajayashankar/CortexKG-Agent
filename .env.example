# Runtime mode
APP_ENV=development

# LLM backends (optional)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Neo4j (required for graph retrieval/loaders)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Qdrant / GraphRAG (active backend)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=vuln_kg_evidence_v1
QDRANT_TOP_K=20
QDRANT_TEXT_FIELD=text
QDRANT_BATCH_SIZE=500

# Pinecone (optional, inactive by default)
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_NAMESPACE=default
PINECONE_MODE=vector
PINECONE_TEXT_FIELD=text
PINECONE_BATCH_SIZE=500
PINECONE_TOP_K=20
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Device for embedding inference: cpu | cuda | gpu | auto | mps
# Set to "cuda" (or "auto") when you have NVIDIA GPU access.
# auto = CUDA if available → MPS (Apple) → CPU fallback
EMBEDDING_DEVICE=cpu
# Batch size: 64 safe for CPU. GPU recommended: 1024 (L4/A100).
# Full KG embed (~6.9M vectors, 384-dim) time estimates:
#   L4  24GB @ 1024 batch fp16: ~14 min embed + ~10 min Qdrant upsert = ~24 min total
#   A100 40GB @ 1024 batch fp16: ~6 min embed + ~10 min Qdrant upsert  = ~16 min total
GRAPHRAG_EMBED_BATCH_SIZE=64

# GraphRAG retrieval/index tuning
GRAPHRAG_USE_VECTOR=0
GRAPHRAG_MAX_COOC_ROWS=0
GRAPHRAG_MAX_CORR_ROWS=0
# 0 = no limit. Full KG embed targets ~6.9M chunks (325k CVE dataset + ~5.1M correlations + 891k co-occurrences).
GRAPHRAG_MAX_TOTAL_CHUNKS=0
# Raise to 25 so all ~15.7 avg correlated edges per CVE are captured (KG has 5.12M CORRELATED_WITH edges).
GRAPHRAG_MAX_REL_PER_CVE=25
GRAPHRAG_MIN_CORR_SCORE=0.60
GRAPHRAG_ENABLE_KG_EDGE_CHUNKS=0
# 0 = no limit per source. Full embed: dataset ~75k chunks, correlations ~5.1M, cooccurrence ~891k.
GRAPHRAG_DATASET_QUOTA=0
GRAPHRAG_COOC_QUOTA=0
GRAPHRAG_CORR_QUOTA=0
GRAPHRAG_DATASET_GROUP_SIZE=10
GRAPHRAG_MIN_COOCCUR_PER_CVE=2
GRAPHRAG_GRAPH_WEIGHT_HOP1=0.88
GRAPHRAG_GRAPH_WEIGHT_HOP2=0.55

# Agent forced GraphRAG query defaults
AGENT_GRAPHRAG_TOP_K=20
AGENT_GRAPHRAG_MAX_HOPS=2
AGENT_GRAPHRAG_USE_VECTOR=0

# Backend hardening
API_KEY=change-me
CORS_ALLOWLIST=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
